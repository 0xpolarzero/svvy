{
  "name": "svvy",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:api": "bun scripts/generate-api-declarations.ts && bun x oxfmt generated/*.generated.ts",
    "start": "bun run generate:api && vite build && electrobun dev",
    "dev": "bun run generate:api && bun scripts/dev.ts",
    "dev:clean": "bun run clean:session-state && bun run dev",
    "clean:session-state": "bun scripts/clean-session-state.ts",
    "build": "bun run generate:api && vite build && electrobun build --env=stable",
    "build:dev": "bun run generate:api && vite build && electrobun build --env=dev",
    "run": "electrobun run",
    "workflow:implement-feature": "bun workflows/scripts/run-implement-feature.ts",
    "check": "bun run typecheck && bun run test:unit && bun run lint:check && bun run format:check && bun run build",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "bun run generate:api && bun test $(rg --files src -g '*.test.ts' -g '*.spec.ts' -g '*_test.ts' -g '*_spec.ts')",
    "setup:e2e": "electrobun-e2e setup --config ./electrobun-e2e.config.ts",
    "test:e2e": "ELECTROBUN_E2E_SHARDS=1 electrobun-e2e run --config ./electrobun-e2e.config.ts",
    "typecheck": "bun run generate:api && bun run typecheck:root && bun run typecheck:workflows",
    "typecheck:root": "tsgo -p tsconfig.json --noEmit",
    "typecheck:workflows": "bun run --cwd workflows typecheck",
    "lint": "oxlint . --import-plugin --node-plugin --deny-warnings --fix --fix-suggestions",
    "lint:check": "oxlint . --import-plugin --node-plugin --deny-warnings",
    "format": "oxfmt $(rg --files -g '*.ts' -g '*.tsx' -g '*.svelte' -g '*.toml' -g '!docs/references/**')",
    "format:check": "oxfmt --check $(rg --files -g '*.ts' -g '*.tsx' -g '*.svelte' -g '*.toml' -g '!docs/references/**')"
  },
  "dependencies": {
    "@fontsource-variable/familjen-grotesk": "^5.2.8",
    "@lucide/svelte": "^1.8.0",
    "@mariozechner/pi-agent-core": "^0.64.0",
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@mdit/plugin-katex": "^0.25.2",
    "@smithers-orchestrator/db": "0.16.8",
    "@tanstack/svelte-form": "^1.32.0",
    "@tanstack/svelte-hotkeys": "^0.10.0",
    "@tanstack/svelte-virtual": "^3.13.24",
    "@tiny-fish/sdk": "0.0.8",
    "cmdk-sv": "^0.0.19",
    "dockview-core": "^6.1.1",
    "electrobun": "1.16.0",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.1",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shiki": "^4.0.2",
    "smithers-orchestrator": "0.16.8",
    "svelte": "^5.55.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "^1.3.11",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/three": "^0.184.0",
    "@typescript/native-preview": "beta",
    "electrobun-browser-tools": "1.0.1",
    "electrobun-e2e": "1.0.2",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "packageManager": "bun@1.3.10"
}
