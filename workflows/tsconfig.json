{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "smithers-orchestrator",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["@types/bun", "@types/mdx", "@types/react", "@types/react-dom", "@types/node"]
  },
  "include": ["./**/*.ts", "./**/*.tsx", "./**/*.mdx"],
  "exclude": ["./node_modules", "./.smithers", "./.worktrees"]
}
